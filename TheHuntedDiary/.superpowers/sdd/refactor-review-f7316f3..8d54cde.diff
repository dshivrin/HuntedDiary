+#!/bin/sh
+
+set -eu
+
+script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+project_file=${1:-"$script_dir/../TheHuntedDiary.xcodeproj/project.pbxproj"}
+
+deployment_targets=$(
+    sed -n 's/^[[:space:]]*IPHONEOS_DEPLOYMENT_TARGET = \([^;]*\);/\1/p' "$project_file"
+)
+
+if [ -z "$deployment_targets" ]; then
+    echo "error: no IPHONEOS_DEPLOYMENT_TARGET settings found in $project_file" >&2
+    exit 1
+fi
+
+unexpected_targets=$(printf '%s\n' "$deployment_targets" | awk '$0 != "26.0"')
+
+if [ -n "$unexpected_targets" ]; then
+    echo "error: expected every IPHONEOS_DEPLOYMENT_TARGET to equal 26.0; found:" >&2
+    printf '%s\n' "$unexpected_targets" | sort | uniq -c >&2
+    exit 1
+fi
+
+target_count=$(printf '%s\n' "$deployment_targets" | wc -l | tr -d ' ')
+echo "Verified $target_count IPHONEOS_DEPLOYMENT_TARGET settings at 26.0."
